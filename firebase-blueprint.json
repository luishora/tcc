{
  "entities": {
    "User": {
      "title": "User",
      "description": "User of the warehouse system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Item": {
      "title": "Item",
      "description": "Inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "quantity", "minStock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Inventory movement (in/out)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "type": { "type": "string", "enum": ["in", "out"] },
        "quantity": { "type": "number" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["itemId", "type", "quantity", "userId", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "critical"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "timestamp"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "App users"
    },
    "items": {
      "schema": "Item",
      "description": "Inventory items"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Log of inputs and outputs"
    },
    "notifications": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
